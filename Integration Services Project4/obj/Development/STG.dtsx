                              dataType="System.String"
                              description="Derived Column Expression"
                              name="Expression">[DATEPART]("dw",#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 1 ? "Saturday" : [DATEPART]("dw",#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 2 ? "Sunday" : [DATEPART]("dw",#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 3 ? "Monday" : [DATEPART]("dw",#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 4 ? "Tuesday" : [DATEPART]("dw",#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 5 ? "Wednesday" : [DATEPART]("dw",#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 6 ? "Thursday" : "Friday"</property>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Friendly Expression"
                              expressionType="Notify"
                              name="FriendlyExpression">DATEPART("dw",converted_date) == 1 ? "Saturday" : DATEPART("dw",converted_date) == 2 ? "Sunday" : DATEPART("dw",converted_date) == 3 ? "Monday" : DATEPART("dw",converted_date) == 4 ? "Tuesday" : DATEPART("dw",converted_date) == 5 ? "Wednesday" : DATEPART("dw",converted_date) == 6 ? "Thursday" : "Friday"</property>
