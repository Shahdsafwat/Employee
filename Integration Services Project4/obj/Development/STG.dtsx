                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Friendly Expression"
                              expressionType="Notify"
                              name="FriendlyExpression">MONTH(converted_date) == 1 ? "January" : MONTH(converted_date) == 2 ? "February" : MONTH(converted_date) == 3 ? "March" : MONTH(converted_date) == 4 ? "April" : MONTH(converted_date) == 5 ? "May" : MONTH(converted_date) == 6 ? "June" : MONTH(converted_date) == 7 ? "July" : MONTH(converted_date) == 8 ? "August" : MONTH(converted_date) == 9 ? "September" : MONTH(converted_date) == 10 ? "October" : MONTH(converted_date) == 11 ? "November" : "December"</property>
