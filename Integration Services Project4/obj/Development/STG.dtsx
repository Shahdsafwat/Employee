                          truncationRowDisposition="FailComponent">
                          <properties>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Expression"
                              name="Expression">[MONTH](#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 1 ? "January" : [MONTH](#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 2 ? "February" : [MONTH](#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 3 ? "March" : [MONTH](#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 4 ? "April" : [MONTH](#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 5 ? "May" : [MONTH](#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 6 ? "June" : [MONTH](#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 7 ? "July" : [MONTH](#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 8 ? "August" : [MONTH](#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 9 ? "September" : [MONTH](#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 10 ? "October" : [MONTH](#{Package\DIM_Sequence\load Dim_date\Data Conversion.Outputs[Data Conversion Output].Columns[converted_date]}) == 11 ? "November" : "December"</property>
